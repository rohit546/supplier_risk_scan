# ── LLM configuration ────────────────────────────────────────
# Provider: gemini | openai | anthropic
# Leave the key empty to run in deterministic fallback mode (no LLM calls).
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM trigger mode: manual | auto
#   manual (default) — alerts are raised "pending"; the LLM is only called when
#     an operator clicks "Run AI Assessment" (POST /api/alerts/{id}/assess).
#   auto — the agent calls the LLM automatically as soon as an alert fires.
LLM_MODE=manual

# Model overrides (optional)
GEMINI_MODEL=gemini-flash-latest
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ── Agent loop ───────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=20
SCAN_BATCH_SIZE=3
ALERT_COOLDOWN_MINUTES=30

# ── API ──────────────────────────────────────────────────────
CORS_ORIGINS=*
